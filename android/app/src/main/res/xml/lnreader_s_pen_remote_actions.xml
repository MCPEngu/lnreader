<?xml version="1.0" encoding="utf-8"?>
<remote-actions version="1.2">
    <action
        id="reader_next_page"
        label="@string/s_pen_remote_next_page"
        priority="1"
        trigger_key="D">
        <preference
            name="gesture"
            value="click" />
    </action>

    <action
        id="reader_prev_page"
        label="@string/s_pen_remote_previous_page"
        priority="2"
        trigger_key="A">
        <preference
            name="gesture"
            value="double_click" />
    </action>

    <action
        id="reader_prev_chapter"
        label="@string/s_pen_remote_previous_chapter"
        priority="3"
        trigger_key="Q">
        <preference
            name="gesture"
            value="swipe_left" />
    </action>

    <action
        id="reader_next_chapter"
        label="@string/s_pen_remote_next_chapter"
        priority="4"
        trigger_key="E">
        <preference
            name="gesture"
            value="swipe_right" />
    </action>
</remote-actions>
